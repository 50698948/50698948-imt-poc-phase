# ── Database ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=imt_poc
DB_USER=imt
DB_PASSWORD=imt_poc_2024

# ── LLM Mode ──
# "offline" = random projection + template (zero external deps, default)
# "openai"  = OpenAI API (needs LLM_API_KEY)
# "custom"  = custom OpenAI-compatible endpoint (Azure, local LLM, proxy)
LLM_MODE=offline

# ── LLM API config (only needed when LLM_MODE != "offline") ──
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
# LLM_EMBEDDING_MODEL=text-embedding-3-small
# LLM_EMBEDDING_DIM=1536

# ── Custom endpoint examples ──
# Azure OpenAI:
#   LLM_MODE=custom
#   LLM_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment
#   LLM_API_KEY=your-azure-key
#   LLM_MODEL=gpt-4o
#
# Local Ollama:
#   LLM_MODE=custom
#   LLM_BASE_URL=http://localhost:11434/v1
#   LLM_MODEL=llama3
#   LLM_EMBEDDING_MODEL=nomic-embed-text
#   LLM_EMBEDDING_DIM=768
